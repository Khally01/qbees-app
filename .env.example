# App
DEBUG=true
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-in-production

# Database (Railway provides this automatically)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/qbees

# Twilio (for phone OTP auth)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Cloudflare R2 (for photo storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=qbees-photos
R2_PUBLIC_URL=

# Default tenant
DEFAULT_TENANT_NAME=Qbees
DEFAULT_TENANT_SLUG=qbees
